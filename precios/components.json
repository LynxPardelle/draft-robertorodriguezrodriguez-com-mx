{
  "version": 1,
  "domain": "robertorodriguezrodriguez.com.mx",
  "pageId": "precios",
  "components": [
    {
      "id": "preciosPage",
      "type": "container",
      "config": {
        "tag": "main",
        "classes": "ank-display-flex ank-flexDirection-column ank-bg-bgColor ank-color-textColor",
        "components": [
          "preciosHero",
          "preciosContent",
          "preciosCta"
        ],
        "styles": {
          "fontFamily": "Aptos, \"Segoe UI\", sans-serif",
          "minHeight": "calc(100vh - 260px)"
        },
        "id": "main-content",
        "role": "main",
        "tabindex": -1
      }
    },
    {
      "id": "preciosHero",
      "type": "container",
      "config": {
        "tag": "section",
        "classes": "ank-width-100per ank-display-flex ank-justifyContent-center ank-paddingInline-16px ank-paddingBlock-56px ank-color-textColor ank-bg-secondaryBgColor",
        "components": [
          "preciosHeroInner"
        ],
        "styles": {
          "paddingBlock": "64px"
        },
        "id": "home"
      }
    },
    {
      "id": "preciosHeroInner",
      "type": "container",
      "config": {
        "tag": "div",
        "classes": "ank-width-100per ank-display-grid ank-gap-16px ank-justifyItems-center ank-textAlign-center",
        "components": [
          "preciosEyebrow",
          "preciosTitle",
          "preciosLead"
        ],
        "styles": {
          "maxWidth": "900px"
        }
      }
    },
    {
      "id": "preciosEyebrow",
      "type": "text",
      "config": {
        "tag": "p",
        "text": "Precios",
        "classes": "ank-m-0 ank-color-linkColor ank-fontSize-0_82rem ank-fontWeight-900 ank-textTransform-uppercase ank-lineHeight-1_2"
      }
    },
    {
      "id": "preciosTitle",
      "type": "text",
      "config": {
        "tag": "h1",
        "text": "Precios claros antes de agendar",
        "classes": "ank-m-0 ank-color-titleColor ank-lineHeight-1_05 ank-fontWeight-800",
        "styles": {
          "maxWidth": "840px",
          "fontFamily": "Georgia, \"Times New Roman\", serif",
          "fontSize": "clamp(2.05rem, 4vw, 3.7rem)"
        }
      }
    },
    {
      "id": "preciosLead",
      "type": "text",
      "config": {
        "tag": "p",
        "text": "La informacion de costos se presenta de forma visible para reducir dudas antes de consultar disponibilidad.",
        "classes": "ank-m-0 ank-color-secondaryTextColor ank-fontSize-1_08rem ank-fontSize-md-1_18rem ank-lineHeight-1_6",
        "styles": {
          "maxWidth": "760px"
        }
      }
    },
    {
      "id": "preciosContent",
      "type": "container",
      "config": {
        "tag": "section",
        "classes": "ank-width-100per ank-display-flex ank-justifyContent-center ank-paddingInline-16px ank-paddingBlock-56px ank-color-textColor ank-bg-bgColor",
        "components": [
          "preciosContentInner"
        ],
        "id": "contenido"
      }
    },
    {
      "id": "preciosContentInner",
      "type": "container",
      "config": {
        "tag": "div",
        "classes": "ank-width-100per ank-display-grid ank-gap-16px",
        "components": [
          "preciosGrid"
        ],
        "styles": {
          "maxWidth": "1040px"
        }
      }
    },
    {
      "id": "preciosGrid",
      "type": "container",
      "config": {
        "tag": "div",
        "classes": "ank-display-grid ank-gap-16px",
        "components": [
          "preciosBlock1",
          "preciosBlock2",
          "preciosBlock3"
        ],
        "styles": {
          "gridTemplateColumns": "repeat(auto-fit, minmax(min(100%, 280px), 1fr))"
        }
      }
    },
    {
      "id": "preciosBlock1",
      "type": "container",
      "config": {
        "tag": "article",
        "classes": "ank-bg-bgColor ank-border-1px__solid__secondaryBgColor ank-padding-20px ank-display-flex ank-flexDirection-column ank-gap-12px",
        "components": [
          "preciosBlock1Title",
          "preciosBlock1Body"
        ],
        "styles": {
          "borderRadius": "6px",
          "boxShadow": "0 16px 38px rgba(49,85,70,0.08)"
        }
      }
    },
    {
      "id": "preciosBlock1Title",
      "type": "text",
      "config": {
        "tag": "h2",
        "text": "Consulta psicologica online",
        "classes": "ank-m-0 ank-color-titleColor ank-fontSize-1_2rem ank-fontWeight-900 ank-lineHeight-1_2"
      }
    },
    {
      "id": "preciosBlock1Body",
      "type": "text",
      "config": {
        "tag": "p",
        "text": "Costo de referencia: $300 MXN. La modalidad, horario y disponibilidad se confirman antes de iniciar.",
        "classes": "ank-m-0 ank-color-secondaryTextColor ank-fontSize-1rem ank-lineHeight-1_65"
      }
    },
    {
      "id": "preciosBlock2",
      "type": "container",
      "config": {
        "tag": "article",
        "classes": "ank-bg-bgColor ank-border-1px__solid__secondaryBgColor ank-padding-20px ank-display-flex ank-flexDirection-column ank-gap-12px",
        "components": [
          "preciosBlock2Title",
          "preciosBlock2Body"
        ],
        "styles": {
          "borderRadius": "6px",
          "boxShadow": "0 16px 38px rgba(49,85,70,0.08)"
        }
      }
    },
    {
      "id": "preciosBlock2Title",
      "type": "text",
      "config": {
        "tag": "h2",
        "text": "Especialidad/autismo",
        "classes": "ank-m-0 ank-color-titleColor ank-fontSize-1_2rem ank-fontWeight-900 ank-lineHeight-1_2"
      }
    },
    {
      "id": "preciosBlock2Body",
      "type": "text",
      "config": {
        "tag": "p",
        "text": "Costo de referencia: $400 MXN. Este servicio requiere confirmar alcance, modalidad y pertinencia antes de publicar o promover.",
        "classes": "ank-m-0 ank-color-secondaryTextColor ank-fontSize-1rem ank-lineHeight-1_65"
      }
    },
    {
      "id": "preciosBlock3",
      "type": "container",
      "config": {
        "tag": "article",
        "classes": "ank-bg-bgColor ank-border-1px__solid__secondaryBgColor ank-padding-20px ank-display-flex ank-flexDirection-column ank-gap-12px",
        "components": [
          "preciosBlock3Title",
          "preciosBlock3Body"
        ],
        "styles": {
          "borderRadius": "6px",
          "boxShadow": "0 16px 38px rgba(49,85,70,0.08)"
        }
      }
    },
    {
      "id": "preciosBlock3Title",
      "type": "text",
      "config": {
        "tag": "h2",
        "text": "Decision informada",
        "classes": "ank-m-0 ank-color-titleColor ank-fontSize-1_2rem ank-fontWeight-900 ank-lineHeight-1_2"
      }
    },
    {
      "id": "preciosBlock3Body",
      "type": "text",
      "config": {
        "tag": "p",
        "text": "Los precios no sustituyen una evaluacion profesional ni implican diagnostico, resultado garantizado o atencion de emergencia.",
        "classes": "ank-m-0 ank-color-secondaryTextColor ank-fontSize-1rem ank-lineHeight-1_65"
      }
    },
    {
      "id": "preciosCta",
      "type": "container",
      "config": {
        "tag": "section",
        "classes": "ank-width-100per ank-display-flex ank-justifyContent-center ank-paddingInline-16px ank-paddingBlock-56px ank-bg-secondaryBgColor ank-color-textColor",
        "components": [
          "preciosCtaInner"
        ],
        "id": "contacto"
      }
    },
    {
      "id": "preciosCtaInner",
      "type": "container",
      "config": {
        "tag": "div",
        "classes": "ank-width-100per ank-display-grid ank-gap-16px ank-justifyItems-center ank-textAlign-center",
        "components": [
          "preciosCtaTitle",
          "preciosCtaBody",
          "preciosCtaLink"
        ],
        "styles": {
          "maxWidth": "780px"
        }
      }
    },
    {
      "id": "preciosCtaTitle",
      "type": "text",
      "config": {
        "tag": "h2",
        "text": "Confirma disponibilidad",
        "classes": "ank-m-0 ank-color-titleColor ank-fontSize-1_8rem ank-fontWeight-900 ank-lineHeight-1_1"
      }
    },
    {
      "id": "preciosCtaBody",
      "type": "text",
      "config": {
        "tag": "p",
        "text": "El canal publico de agenda se agregara solo cuando este autorizado para el sitio.",
        "classes": "ank-m-0 ank-color-secondaryTextColor ank-fontSize-1rem ank-lineHeight-1_6",
        "styles": {
          "maxWidth": "680px"
        }
      }
    },
    {
      "id": "preciosCtaLink",
      "type": "link",
      "config": {
        "href": "/contacto",
        "text": "Ir a contacto",
        "ariaLabel": "Ir a contacto",
        "classes": "ank-display-inline-flex ank-alignItems-center ank-justifyContent-center ank-paddingInline-18px ank-paddingBlock-12px ank-bg-successColor ank-color-onSuccessColor ank-fontWeight-900 ank-textDecoration-none ank-border-1px__solid__successColor ank-textAlign-center",
        "target": "_self",
        "styles": {
          "borderRadius": "999px",
          "color": "var(--ank-onSuccessColor)"
        }
      }
    }
  ]
}
