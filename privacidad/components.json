{
  "version": 1,
  "domain": "robertorodriguezrodriguez.com.mx",
  "pageId": "privacidad",
  "components": [
    {
      "id": "privacidadPage",
      "type": "container",
      "config": {
        "tag": "main",
        "classes": "ank-display-flex ank-flexDirection-column ank-bg-bgColor ank-color-textColor",
        "components": [
          "privacidadHero",
          "privacidadContent"
        ],
        "styles": {
          "fontFamily": "Aptos, \"Segoe UI\", sans-serif",
          "minHeight": "calc(100vh - 260px)"
        },
        "id": "main-content",
        "role": "main",
        "tabindex": -1
      }
    },
    {
      "id": "privacidadHero",
      "type": "container",
      "config": {
        "tag": "section",
        "classes": "ank-width-100per ank-display-flex ank-justifyContent-center ank-paddingInline-16px ank-paddingBlock-56px ank-color-textColor ank-bg-secondaryBgColor",
        "components": [
          "privacidadHeroBrainDecor",
          "privacidadHeroInner"
        ],
        "styles": {
          "paddingBlock": "64px",
          "position": "relative",
          "overflow": "hidden",
          "isolation": "isolate"
        },
        "id": "home"
      }
    },
    {
      "id": "privacidadHeroInner",
      "type": "container",
      "config": {
        "tag": "div",
        "classes": "ank-width-100per ank-maxWidth-900px ank-display-flex ank-flexDirection-column ank-gap-14px",
        "components": [
          "privacidadEyebrow",
          "privacidadTitle",
          "privacidadLead"
        ]
      }
    },
    {
      "id": "privacidadEyebrow",
      "type": "text",
      "config": {
        "tag": "p",
        "text": "Roberto Rodríguez Rodríguez",
        "classes": "ank-m-0 ank-color-linkColor ank-fontSize-0_82rem ank-fontWeight-900 ank-textTransform-uppercase ank-lineHeight-1_2"
      }
    },
    {
      "id": "privacidadTitle",
      "type": "text",
      "config": {
        "tag": "h1",
        "text": "Aviso de privacidad",
        "classes": "ank-m-0 ank-color-titleColor ank-fontSize-2_1rem ank-fontSize-md-3_2rem ank-lineHeight-1_05 ank-fontWeight-800",
        "styles": {
          "fontFamily": "Georgia, \"Times New Roman\", serif"
        }
      }
    },
    {
      "id": "privacidadLead",
      "type": "text",
      "config": {
        "tag": "p",
        "text": "Información sobre el uso de datos en el sitio de Roberto Rodríguez Rodríguez.",
        "classes": "ank-m-0 ank-color-secondaryTextColor ank-fontSize-1rem ank-lineHeight-1_65"
      }
    },
    {
      "id": "privacidadContent",
      "type": "container",
      "config": {
        "tag": "section",
        "classes": "ank-width-100per ank-display-flex ank-justifyContent-center ank-paddingInline-16px ank-paddingBlock-56px ank-color-textColor ank-bg-bgColor",
        "components": [
          "privacidadContentBrainDecor",
          "privacidadContentInner"
        ],
        "id": "contenido",
        "styles": {
          "position": "relative",
          "overflow": "hidden",
          "isolation": "isolate"
        }
      }
    },
    {
      "id": "privacidadContentInner",
      "type": "container",
      "config": {
        "tag": "div",
        "classes": "ank-width-100per ank-maxWidth-900px ank-display-flex ank-flexDirection-column ank-gap-16px",
        "components": [
          "privacidadBlock1",
          "privacidadBlock2",
          "privacidadBlock3"
        ]
      }
    },
    {
      "id": "privacidadBlock1",
      "type": "container",
      "config": {
        "tag": "article",
        "classes": "ank-bg-bgColor ank-border-1px__solid__secondaryBgColor ank-borderRadius-8px ank-padding-20px ank-display-flex ank-flexDirection-column ank-gap-12px",
        "components": [
          "privacidadBlock1Title",
          "privacidadBlock1Body"
        ],
        "styles": {
          "borderRadius": "6px",
          "boxShadow": "0 16px 38px rgba(49,85,70,0.08)"
        }
      }
    },
    {
      "id": "privacidadBlock1Title",
      "type": "text",
      "config": {
        "tag": "h2",
        "text": "Datos de contacto",
        "classes": "ank-m-0 ank-color-titleColor ank-fontSize-1_08rem ank-fontWeight-800 ank-lineHeight-1_25"
      }
    },
    {
      "id": "privacidadBlock1Body",
      "type": "text",
      "config": {
        "tag": "p",
        "text": "Los canales públicos para solicitar consulta son WhatsApp +52 1 55 4189 2942 y correo r.rodriguez_r@outlook.com.",
        "classes": "ank-m-0 ank-color-secondaryTextColor ank-fontSize-1rem ank-lineHeight-1_65"
      }
    },
    {
      "id": "privacidadBlock2",
      "type": "container",
      "config": {
        "tag": "article",
        "classes": "ank-bg-bgColor ank-border-1px__solid__secondaryBgColor ank-borderRadius-8px ank-padding-20px ank-display-flex ank-flexDirection-column ank-gap-12px",
        "components": [
          "privacidadBlock2Title",
          "privacidadBlock2Body"
        ],
        "styles": {
          "borderRadius": "6px",
          "boxShadow": "0 16px 38px rgba(49,85,70,0.08)"
        }
      }
    },
    {
      "id": "privacidadBlock2Title",
      "type": "text",
      "config": {
        "tag": "h2",
        "text": "Uso de información",
        "classes": "ank-m-0 ank-color-titleColor ank-fontSize-1_08rem ank-fontWeight-800 ank-lineHeight-1_25"
      }
    },
    {
      "id": "privacidadBlock2Body",
      "type": "text",
      "config": {
        "tag": "p",
        "text": "La información enviada por canales de contacto se usara para responder solicitudes de consulta, dar seguimiento a disponibilidad y mantener comunicación relacionada con la atención solicitada.",
        "classes": "ank-m-0 ank-color-secondaryTextColor ank-fontSize-1rem ank-lineHeight-1_65"
      }
    },
    {
      "id": "privacidadBlock3",
      "type": "container",
      "config": {
        "tag": "article",
        "classes": "ank-bg-bgColor ank-border-1px__solid__secondaryBgColor ank-borderRadius-8px ank-padding-20px ank-display-flex ank-flexDirection-column ank-gap-12px",
        "components": [
          "privacidadBlock3Title",
          "privacidadBlock3Body"
        ],
        "styles": {
          "borderRadius": "6px",
          "boxShadow": "0 16px 38px rgba(49,85,70,0.08)"
        }
      }
    },
    {
      "id": "privacidadBlock3Title",
      "type": "text",
      "config": {
        "tag": "h2",
        "text": "Confidencialidad",
        "classes": "ank-m-0 ank-color-titleColor ank-fontSize-1_08rem ank-fontWeight-800 ank-lineHeight-1_25"
      }
    },
    {
      "id": "privacidadBlock3Body",
      "type": "text",
      "config": {
        "tag": "p",
        "text": "La consulta psicológica se presenta como un espacio profesional, privado y respetuoso. La información de contacto y seguimiento se maneja con criterios de confidencialidad y uso limitado a la atención solicitada.",
        "classes": "ank-m-0 ank-color-secondaryTextColor ank-fontSize-1rem ank-lineHeight-1_65"
      }
    },
    {
      "id": "privacidadHeroBrainDecor",
      "type": "container",
      "config": {
        "tag": "div",
        "classes": "ank-display-block",
        "components": [
          "privacidadHeroBrainDecorImage"
        ],
        "role": "presentation",
        "styles": {
          "position": "absolute",
          "pointerEvents": "none",
          "zIndex": "0",
          "width": "clamp(70px, 7vw, 116px)",
          "aspectRatio": "1 / 1",
          "opacity": "0.86",
          "filter": "drop-shadow(0 10px 18px rgba(49,85,70,0.16)) drop-shadow(0 1px 0 rgba(255,255,255,0.85))",
          "transform": "rotate(5deg)",
          "right": "max(12px, calc((100vw - 900px) / 2 + 8px))",
          "top": "clamp(10px, 2vw, 24px)"
        }
      }
    },
    {
      "id": "privacidadHeroBrainDecorImage",
      "type": "media",
      "config": {
        "tag": "image",
        "src": "https://assets.zoolandingpage.com.mx/robertorodriguezrodriguez.com.mx/shared/mascot-images/brain-reading.png",
        "alt": " ",
        "classes": "ank-width-100per ank-height-100per ank-display-block ank-objectFit-contain",
        "width": 420,
        "height": 420,
        "decoding": "async",
        "loading": "eager"
      }
    },
    {
      "id": "privacidadContentBrainDecor",
      "type": "container",
      "config": {
        "tag": "div",
        "classes": "ank-display-block",
        "components": [
          "privacidadContentBrainDecorImage"
        ],
        "role": "presentation",
        "styles": {
          "position": "absolute",
          "pointerEvents": "none",
          "zIndex": "0",
          "width": "clamp(48px, 6vw, 96px)",
          "aspectRatio": "1 / 1",
          "opacity": "0.82",
          "filter": "drop-shadow(0 10px 18px rgba(49,85,70,0.16)) drop-shadow(0 1px 0 rgba(255,255,255,0.85))",
          "transform": "rotate(-4deg)",
          "left": "max(12px, calc((100vw - 1040px) / 2 - 128px))",
          "top": "clamp(4px, 1vw, 12px)"
        }
      }
    },
    {
      "id": "privacidadContentBrainDecorImage",
      "type": "media",
      "config": {
        "tag": "image",
        "src": "https://assets.zoolandingpage.com.mx/robertorodriguezrodriguez.com.mx/shared/mascot-images/brain-checklist.png",
        "alt": " ",
        "classes": "ank-width-100per ank-height-100per ank-display-block ank-objectFit-contain",
        "width": 420,
        "height": 420,
        "decoding": "async",
        "loading": "eager"
      }
    }
  ]
