      }
    },
    {
      "id": "terminosBlock1Title",
      "type": "text",
      "config": {
        "tag": "h2",
        "text": "Alcance del servicio",
        "classes": "ank-m-0 ank-color-titleColor ank-fontSize-1_08rem ank-fontWeight-800 ank-lineHeight-1_25"
      }
    },
    {
      "id": "terminosBlock1Body",
      "type": "text",
      "config": {
        "tag": "p",
        "text": "Este sitio presenta servicios de consulta psicologica online. No sustituye servicios de emergencia, atencion medica urgente ni atencion psiquiatrica.",
        "classes": "ank-m-0 ank-color-secondaryTextColor ank-fontSize-1rem ank-lineHeight-1_65"
      }
    },
    {
      "id": "terminosBlock2",
      "type": "container",
      "config": {
        "tag": "article",
        "classes": "ank-bg-bgColor ank-border-1px__solid__secondaryBgColor ank-borderRadius-8px ank-padding-20px ank-display-flex ank-flexDirection-column ank-gap-12px",
        "components": [
          "terminosBlock2Title",
          "terminosBlock2Body"
        ],
        "styles": {
          "borderRadius": "6px",
          "boxShadow": "0 16px 38px rgba(49,85,70,0.08)"
        }
      }
    },
    {
      "id": "terminosBlock2Title",
      "type": "text",
      "config": {
        "tag": "h2",
        "text": "Agendamiento y costos",
        "classes": "ank-m-0 ank-color-titleColor ank-fontSize-1_08rem ank-fontWeight-800 ank-lineHeight-1_25"
      }
    },
    {
      "id": "terminosBlock2Body",
      "type": "text",
      "config": {
        "tag": "p",
        "text": "Los precios son consulta psicologica online por $300 y consulta de especialidad/autismo por $400. La disponibilidad y modalidad se confirman antes de agendar.",
        "classes": "ank-m-0 ank-color-secondaryTextColor ank-fontSize-1rem ank-lineHeight-1_65"
      }
    },
    {
      "id": "terminosBlock3",
      "type": "container",
      "config": {
        "tag": "article",
        "classes": "ank-bg-bgColor ank-border-1px__solid__secondaryBgColor ank-borderRadius-8px ank-padding-20px ank-display-flex ank-flexDirection-column ank-gap-12px",
        "components": [
          "terminosBlock3Title",
          "terminosBlock3Body"
        ],
        "styles": {
          "borderRadius": "6px",
          "boxShadow": "0 16px 38px rgba(49,85,70,0.08)"
        }
      }
    },
    {
      "id": "terminosBlock3Title",
      "type": "text",
      "config": {
        "tag": "h2",
        "text": "Uso responsable",
        "classes": "ank-m-0 ank-color-titleColor ank-fontSize-1_08rem ank-fontWeight-800 ank-lineHeight-1_25"
      }
    },
    {
      "id": "terminosBlock3Body",
      "type": "text",
      "config": {
        "tag": "p",
        "text": "Si existe riesgo inmediato, crisis o emergencia, se debe buscar apoyo de servicios de emergencia o lineas locales de atencion urgente.",
        "classes": "ank-m-0 ank-color-secondaryTextColor ank-fontSize-1rem ank-lineHeight-1_65"
      }
    }
  ]
