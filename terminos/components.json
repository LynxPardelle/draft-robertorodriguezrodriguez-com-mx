        "classes": "ank-m-0 ank-color-titleColor ank-fontSize-2_1rem ank-fontSize-md-3_2rem ank-lineHeight-1_05 ank-fontWeight-800",
        "styles": {
          "fontFamily": "Georgia, \"Times New Roman\", serif"
        }
      }
    },
    {
      "id": "terminosLead",
      "type": "text",
      "config": {
        "tag": "p",
        "text": "Condiciones generales del sitio y limites del servicio de consulta psicologica online.",
        "classes": "ank-m-0 ank-color-secondaryTextColor ank-fontSize-1rem ank-lineHeight-1_65"
      }
    },
    {
      "id": "terminosContent",
      "type": "container",
      "config": {
        "tag": "section",
        "classes": "ank-width-100per ank-display-flex ank-justifyContent-center ank-paddingInline-16px ank-paddingBlock-56px ank-color-textColor ank-bg-bgColor",
        "components": [
          "terminosContentInner"
        ],
        "id": "contenido"
      }
    },
    {
      "id": "terminosContentInner",
      "type": "container",
      "config": {
        "tag": "div",
        "classes": "ank-width-100per ank-maxWidth-900px ank-display-flex ank-flexDirection-column ank-gap-16px",
        "components": [
          "terminosBlock1",
          "terminosBlock2",
          "terminosBlock3"
        ]
      }
    },
    {
      "id": "terminosBlock1",
      "type": "container",
      "config": {
        "tag": "article",
        "classes": "ank-bg-bgColor ank-border-1px__solid__secondaryBgColor ank-borderRadius-8px ank-padding-20px ank-display-flex ank-flexDirection-column ank-gap-12px",
        "components": [
          "terminosBlock1Title",
          "terminosBlock1Body"
        ],
        "styles": {
          "borderRadius": "6px",
          "boxShadow": "0 16px 38px rgba(49,85,70,0.08)"
