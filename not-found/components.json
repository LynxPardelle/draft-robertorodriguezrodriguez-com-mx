{
  "version": 1,
  "domain": "robertorodriguezrodriguez.com.mx",
  "pageId": "not-found",
  "components": [
    {
      "id": "notFoundPage",
      "type": "container",
      "config": {
        "tag": "main",
        "classes": "ank-display-flex ank-flexDirection-column ank-bg-bgColor ank-color-textColor",
        "components": [
          "notFoundSection"
        ],
        "styles": {
          "fontFamily": "Aptos, \"Segoe UI\", sans-serif",
          "minHeight": "calc(100vh - 260px)"
        },
        "id": "main-content",
        "role": "main",
        "tabindex": -1
      }
    },
    {
      "id": "notFoundSection",
      "type": "container",
      "config": {
        "tag": "section",
        "classes": "ank-width-100per ank-display-flex ank-justifyContent-center ank-paddingInline-16px ank-paddingBlock-56px ank-color-textColor ank-bg-bgColor",
        "components": [
          "notFoundBrainDecor",
          "notFoundInner"
        ],
        "styles": {
          "minHeight": "68vh",
          "position": "relative",
          "overflow": "hidden",
          "isolation": "isolate"
        }
      }
    },
    {
      "id": "notFoundInner",
      "type": "container",
      "config": {
        "tag": "div",
        "classes": "ank-width-100per ank-maxWidth-760px ank-display-flex ank-flexDirection-column ank-gap-16px ank-padding-28px ank-border-1px__solid__secondaryBgColor ank-borderRadius-8px",
        "components": [
          "notFoundEyebrow",
          "notFoundTitle",
          "notFoundLead",
          "notFoundActions"
        ],
        "styles": {
          "borderRadius": "8px",
          "backgroundColor": "var(--ank-secondaryBgColor)"
        }
      }
    },
    {
      "id": "notFoundEyebrow",
      "type": "text",
      "config": {
        "tag": "p",
        "text": "404",
        "classes": "ank-m-0 ank-color-linkColor ank-fontSize-0_82rem ank-fontWeight-900 ank-textTransform-uppercase ank-lineHeight-1_2"
      }
    },
    {
      "id": "notFoundTitle",
      "type": "text",
      "config": {
        "tag": "h1",
        "text": "Página no encontrada",
        "classes": "ank-m-0 ank-color-titleColor ank-fontSize-2_1rem ank-fontSize-md-3_2rem ank-lineHeight-1_05 ank-fontWeight-800",
        "styles": {
          "fontFamily": "Georgia, \"Times New Roman\", serif"
        }
      }
    },
    {
      "id": "notFoundLead",
      "type": "text",
      "config": {
        "tag": "p",
        "text": "Puedes volver al inicio o revisar la información principal del sitio para encontrar la ruta adecuada.",
        "classes": "ank-m-0 ank-color-secondaryTextColor ank-fontSize-1rem ank-lineHeight-1_65"
      }
    },
    {
      "id": "notFoundActions",
      "type": "container",
      "config": {
        "tag": "div",
        "classes": "ank-display-flex ank-flexWrap-wrap ank-gap-12px",
        "components": [
          "notFoundHome",
          "notFoundContact"
        ]
      }
    },
    {
      "id": "notFoundHome",
      "type": "link",
      "config": {
        "href": "/",
        "text": "Volver al inicio",
        "ariaLabel": "Volver al inicio",
        "classes": "ank-d-block ank-alignItems-center ank-justifyContent-center ank-paddingInline-18px ank-paddingBlock-12px ank-borderRadius-8px ank-bg-successColor ank-color-onSuccessColor ank-fontWeight-900 ank-textDecoration-none ank-border-1px__solid__successColor ank-textAlign-center",
        "target": "_self",
        "styles": {
          "color": "var(--ank-onSuccessColor)",
          "whiteSpace": "normal",
          "maxWidth": "100%"
        }
      }
    },
    {
      "id": "notFoundContact",
      "type": "link",
      "config": {
        "href": "/#contacto",
        "text": "Agendar cita",
        "ariaLabel": "Agendar cita",
        "classes": "ank-d-block ank-alignItems-center ank-justifyContent-center ank-paddingInline-18px ank-paddingBlock-12px ank-borderRadius-8px ank-bg-bgColor ank-color-linkColor ank-fontWeight-900 ank-textDecoration-none ank-border-1px__solid__linkColor ank-textAlign-center",
        "target": "_self",
        "styles": {
          "whiteSpace": "normal",
          "maxWidth": "100%"
        }
      }
    },
    {
      "id": "notFoundBrainDecor",
      "type": "container",
      "config": {
        "tag": "div",
        "classes": "ank-display-block",
        "components": [
          "notFoundBrainDecorImage"
        ],
        "role": "presentation",
        "styles": {
          "position": "absolute",
          "pointerEvents": "none",
          "zIndex": "0",
          "width": "clamp(74px, 8vw, 124px)",
          "aspectRatio": "1 / 1",
          "opacity": "0.90",
          "filter": "drop-shadow(0 10px 18px rgba(49,85,70,0.16)) drop-shadow(0 1px 0 rgba(255,255,255,0.85))",
          "transform": "rotate(8deg)",
          "right": "max(12px, calc((100vw - 900px) / 2 + 8px))",
          "top": "clamp(10px, 2vw, 24px)"
        }
      }
    },
    {
      "id": "notFoundBrainDecorImage",
      "type": "media",
      "config": {
        "tag": "image",
        "src": "https://assets.zoolandingpage.com.mx/robertorodriguezrodriguez.com.mx/shared/mascot-images/brain-waving.png",
        "alt": " ",
        "classes": "ank-width-100per ank-height-100per ank-display-block ank-objectFit-contain",
        "width": 420,
        "height": 420,
        "decoding": "async",
        "loading": "eager"
      }
    }
  ]
}
